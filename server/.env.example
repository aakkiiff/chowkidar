ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

SERVER_PORT=8080
JWT_SECRET=change-this-to-a-random-string

DB_PATH=./db/chowkidar.db

RETENTION_DAYS_CONTAINERS=7

# ── Container log storage ────────────────────────────────────────────────────
# Logs are appended as NDJSON to one active file per (agent, container):
#   <LOG_DIR>/<agent_id>/<container_name>.log
# When the active file hits LOG_MAX_FILE_MB it is gzipped with a timestamp
# suffix and a fresh active file is opened. Old rotations are pruned by both
# count (LOG_MAX_ROTATIONS) and age (LOG_RETENTION_DAYS).

# Root directory for log files. Must be writable by the server process.
# Keep it on a disk with enough headroom for the worst-case size:
#   agents × containers × LOG_MAX_FILE_MB × (LOG_MAX_ROTATIONS + 1)
# e.g. 20 agents × 30 containers × 100 MB × 11 ≈ 660 GB absolute ceiling.
LOG_DIR=./db/logs

# Maximum age (in days) of rotated .gz files. Anything older is deleted on
# the hourly prune tick, regardless of rotation count. The currently-active
# (uncompressed) file is never deleted by age — only by rotation.
# Raise this for longer forensic history; lower it to save disk.
LOG_RETENTION_DAYS=14

# Size threshold (in MB) at which the active file is rotated and gzipped.
# Larger values = fewer rotations, bigger grep targets, more memory during
# compression. Smaller values = more file handles churn, more .gz files
# to scan for historical queries. 100 MB is a good balance for most workloads.
LOG_MAX_FILE_MB=100

# Maximum number of gzipped rotations kept per container. Oldest is deleted
# first when this count is exceeded. This is the primary knob that bounds
# per-container disk usage:
#   max_bytes_per_container ≈ LOG_MAX_FILE_MB × (LOG_MAX_ROTATIONS + 1)
# The "+1" accounts for the current active file.
LOG_MAX_ROTATIONS=10
